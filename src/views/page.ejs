<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#090b0f" />
    <title><%= page.title %> - RomaOS</title>
    <link rel="stylesheet" href="/page.css" />
  </head>
  <body>
    <main class="shell">
      <a class="brand" href="/">R/ <span>ROMAOS</span></a>
      <p class="eyebrow"><%= page.eyebrow %></p>
      <h1><%= page.title %></h1>
      <% for (const paragraph of page.text) { %><p class="copy"><%= paragraph %></p><% } %>
      <nav>
        <% for (const link of page.links || []) { %><a href="<%= link.href %>"><%= link.label %> <span>↗</span></a><% } %>
      </nav>
    </main>
  </body>
</html>
